def read_sensors():
    data = input("Enter 6 sensor values (e.g. 001100): ")

    sensors = list(map(int, data))

    active = len(list(filter(lambda x: x == 1, sensors)))

    return sensors, active
def decide_movement(sensors):

    if sensors == [0, 0, 0, 0, 0, 0]:
        return "Stop Robot"

    if sensors == [1, 1, 1, 1, 1, 1]:
        return "Junction Detected"

    if sensors[2] == 1 or sensors[3] == 1:
        return "Move Forward"

    if sensors[0] == 1 or sensors[1] == 1:
        return "Turn Left"

    if sensors[4] == 1 or sensors[5] == 1:
